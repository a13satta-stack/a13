# MongoDB connection. This file is committed — keep real credentials in a local
# `.env` (git-ignored) and leave only placeholders here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# Local instead of Atlas:
# MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=a7satta

# Timezone the result dates belong to. Every game declares on an India clock,
# so leave this alone unless the games themselves move.
SITE_TZ=Asia/Kolkata

# Canonical origin, no trailing slash. Every canonical link, og:url, sitemap
# entry and robots.txt Sitemap line is built from this. Set it on staging and
# preview deploys too, or they will tell Google their pages live on production
# and compete with it.
NEXT_PUBLIC_SITE_URL=https://a13satta.com

# ---- Upstream result sync (app/lib/sync.ts) --------------------------------
# Results are pulled from a7satta ONLY when an admin clicks "Fetch results" in
# the panel. Public pages never contact a7satta — they render from the database.
# This flag only gates the old page-load auto-sync (no longer wired); the admin
# button works regardless of it.
A7_SYNC_ENABLED=0

# Only relevant to the old page-load auto-sync; the admin button always pulls now.
A7_SYNC_MIN_INTERVAL_MS=3000

# Where the admin "Fetch results" button pulls from, and how long it waits.
A7_ORIGIN=https://a7satta.com
A7_TIMEOUT_MS=20000

# Let the sync replace the marquee notices with upstream's notifications. Off by
# default so it can't overwrite notices you set in admin. A manual
# POST /api/import still imports them.
A7_SYNC_NOTICES=0

# Lets an external scheduler POST /api/sync without an admin session:
#   curl -X POST -H "Authorization: Bearer <secret>" http://localhost:3000/api/sync
CRON_SECRET=
